# Docker / developer config (Postgres + relative paths from /app)
database:
  driver: postgres
  host: localhost
  port: 5432
  user: spacemosquito
  password: spacemosquito
  dbname: spacemosquito
  sslmode: disable

storage:
  base_path: ./saved

session:
  encryption_key: ""
  file_path: ./session.enc

# browser:
#   path: /usr/bin/chromium   # optional; CHROMIUM_PATH env overrides this

embedder:
  model: nomic-embed-text

mcp:
  port: 8081
  host: "0.0.0.0"
  session_timeout: 3600
  expose_internal_ids: false

cron:
  full_crawl:
    enabled: false
    interval: "24h"
    max_duration: "4h"
    spaces:
      - "https://company.atlassian.net/wiki/spaces/PROJ"
  incremental:
    enabled: false
    interval: "2h"
    max_duration: "30m"
    detection: "dom"
    spaces:
      - "https://company.atlassian.net/wiki/spaces/PROJ"

# --- Dockerless defaults (created by `spacemosquito init`) ---
# Data directory: ~/.spacemosquito/  (override with SPACEMOSQUITO_DATA_DIR or --data-dir)
#
# database:
#   driver: sqlite
#   path: spacemosquito.db
# storage:
#   base_path: ~/.spacemosquito/saved
# session:
#   encryption_key: <auto-generated on init>
#   file_path: ~/.spacemosquito/session.enc
# mcp:
#   host: "127.0.0.1"
