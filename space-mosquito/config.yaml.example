database:
  host: localhost
  port: 5432
  user: spacemosquito
  password: spacemosquito
  dbname: spacemosquito
  sslmode: disable

storage:
  base_path: ./saved

# WARNING: Generate a secure encryption key (never use defaults).
# Run: openssl rand -base64 32
session:
  encryption_key: ""
  file_path: ~/.config/spacemosquito/session.enc

embedder:
  model: nomic-embed-text
  # openai:
  #   api_key: ""
  #   model: text-embedding-3-small

mcp:
  port: 8081
  host: "0.0.0.0"
  session_timeout: 3600
  expose_internal_ids: false

cron:
  full_crawl:
    enabled: false
    interval: "24h"
    max_duration: "4h"
    spaces:
      - "https://company.atlassian.net/wiki/spaces/PROJ"
  incremental:
    enabled: false
    interval: "2h"
    max_duration: "30m"
    detection: "dom"  # "api" | "dom" | disabled by re-crawling all
    spaces:
      - "https://company.atlassian.net/wiki/spaces/PROJ"
