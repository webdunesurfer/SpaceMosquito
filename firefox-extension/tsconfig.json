{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "node",
    "strict": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": "./dist",
    "rootDir": ".",
    "declaration": false,
    "sourceMap": true,
    "noImplicitAny": false
  },
  "include": ["lib/**/*", "background.ts", "content/**/*", "popup/**/*"],
  "exclude": ["node_modules", "dist"]
}
