# Session encryption key (AES-256, 32 bytes).
# Generate a secure key: openssl rand -base64 32
SESSION_ENCRYPTION_KEY=your-32-character-encryption-key-here

# OpenAI API key (optional, only if using OpenAI embeddings)
OPENAI_API_KEY=your-openai-api-key-here

# Database password (must be at least 8 characters)
POSTGRES_PASSWORD=spacemosquito

# Database URL (alternative to individual db config fields)
DATABASE_URL=postgres://spacemosquito:${POSTGRES_PASSWORD}@localhost:5432/spacemosquito?sslmode=disable

# Config file path
CONFIG_PATH=~/.config/spacemosquito/config.yaml
